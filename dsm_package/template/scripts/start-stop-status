#!/bin/sh

PKG_ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
TARGET_ROOT="${PKG_ROOT}/target"
VAR_DIR="${SYNOPKG_PKGVAR:-${PKG_ROOT}/var}"
PID_FILE="${VAR_DIR}/pcpowerfree.pid"
LOG_FILE="${VAR_DIR}/pc_power_agent.log"
INIT_SCRIPT="${TARGET_ROOT}/app/dsm_runtime/init.sh"
RUNNER_SCRIPT="${TARGET_ROOT}/app/dsm_runtime/run-agent.sh"

mkdir -p "${VAR_DIR}"

read_pid() {
    if [ -f "${PID_FILE}" ]; then
        cat "${PID_FILE}"
    fi
}

is_running() {
    PID="$(read_pid)"
    [ -n "${PID}" ] && kill -0 "${PID}" 2>/dev/null
}

stop_process() {
    PID="$(read_pid)"
    if [ -z "${PID}" ]; then
        return 0
    fi

    kill "${PID}" 2>/dev/null || true

    COUNTER=0
    while kill -0 "${PID}" 2>/dev/null; do
        COUNTER=$((COUNTER + 1))
        if [ "${COUNTER}" -ge 10 ]; then
            kill -9 "${PID}" 2>/dev/null || true
            break
        fi
        sleep 1
    done

    rm -f "${PID_FILE}"
}

case "$1" in
    prestart)
        if [ ! -x "${INIT_SCRIPT}" ]; then
            echo "Missing DSM init script: ${INIT_SCRIPT}" >> "${LOG_FILE}"
            exit 1
        fi
        "${INIT_SCRIPT}" --ensure-config >> "${LOG_FILE}" 2>&1
        exit $?
        ;;
    start)
        if is_running; then
            exit 0
        fi
        if [ ! -x "${RUNNER_SCRIPT}" ]; then
            echo "Missing DSM runner script: ${RUNNER_SCRIPT}" >> "${LOG_FILE}"
            exit 1
        fi
        nohup "${RUNNER_SCRIPT}" >> "${LOG_FILE}" 2>&1 &
        echo "$!" > "${PID_FILE}"
        sleep 1
        if is_running; then
            exit 0
        fi
        rm -f "${PID_FILE}"
        exit 1
        ;;
    prestop)
        exit 0
        ;;
    stop)
        stop_process
        exit 0
        ;;
    status)
        if is_running; then
            exit 0
        fi
        if [ -f "${PID_FILE}" ]; then
            exit 1
        fi
        exit 3
        ;;
esac

exit 1
